############################################
# Gemini generated docs (避免規格文件進入 Git Changes)
# 依你現在 dev-doc-mcp 的預設 output_dir 設計
############################################
docs/requirements/
docs/runbooks/
docs/deploy/
docs/db/
docs/specs/
docs/_generated/
docs/flowchart/

############################################
# Gemini: ignore nested .gemini folders in subpackages (optional but practical)
############################################
**/.gemini/
!/.gemini/
!.gemini/settings.json
!.gemini/skills/
!.gemini/skills/**
!.gemini/commands/
!.gemini/commands/**
!.gemini/GEMINI.md
