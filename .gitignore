############################################
.env
.env.*
!.env.example
!.env.template

# Gemini project secrets
.gemini/.env
.gemini/.env.*
!.gemini/.env.example

############################################
# Logs
############################################
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

############################################
# Build artifacts
############################################
dist/
build/
out/
*.tsbuildinfo

############################################
