# GEMINI Settings
# GEMINI_API_KEY=通常抓環境變數，若需要指定api key 則可以在此處定義。

# 如果要控制 file-mcp 的 allow roots，也可以放這裡
FILE_MCP_ROOTS="YOUR_PROJECT_ROOT;Other allow roots..."

# Redmine MCP
REDMINE_URL="YOUR_REDMINE_URL"
REDMINE_API_KEY="YOUR_REDMINE_API_KEY"

# MsSQL (dev-doc-mcp)
# 建議使用唯讀帳號，只查 metadata，不查資料列
MSSQL_CONN="Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASS;Encrypt=true;TrustServerCertificate=true;"
