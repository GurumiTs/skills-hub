# GEMINI Settings
# GEMINI_API_KEY=通常抓環境變數，若需要指定api key 則可以在此處定義。

# 如果要控制 file-mcp 的 allow roots，也可以放這裡
FILE_MCP_ROOTS="YOUR_PROJECT_ROOT;Other allow roots..."

# Redmine MCP
REDMINE_URL="YOUR_REDMINE_URL"
REDMINE_API_KEY="YOUR_REDMINE_API_KEY"

# MsSQL (dev-doc-mcp)
# 建議使用唯讀帳號，只查 metadata，不查資料列
MSSQL_CONN="Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASS;Encrypt=true;TrustServerCertificate=true;"

# Git MCP
# 若未設定，會 fallback 到 FILE_MCP_ROOTS 或 process.cwd()
GIT_MCP_ROOTS="YOUR_PROJECT_ROOT;Other git roots..."

# DB Metadata MCP
# 建議使用唯讀帳號。若未設定，會 fallback 到 MSSQL_CONN。
DB_METADATA_MSSQL_CONN="Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_READONLY_USER;Password=YOUR_PASSWORD;Encrypt=true;TrustServerCertificate=true;"

# Test Runner MCP
# Commands 必須是 JSON object，value 必須是 string array，避免 shell injection。
TEST_RUNNER_ROOTS="YOUR_PROJECT_ROOT;Other test roots..."
TEST_RUNNER_COMMANDS='{"npm-test":["npm","test"],"dotnet-test":["dotnet","test"]}'

# Static Analysis MCP
STATIC_ANALYSIS_ROOTS="YOUR_PROJECT_ROOT;Other analysis roots..."
STATIC_ANALYSIS_COMMANDS='{"npm-lint":["npm","run","lint"],"npm-build":["npm","run","build"],"dotnet-build":["dotnet","build"]}'

# Secret Scan MCP
SECRET_SCAN_ROOTS="YOUR_PROJECT_ROOT;Other scan roots..."
