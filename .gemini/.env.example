# GEMINI Settings
# GEMINI_API_KEY=通常抓環境變數，若需要指定api key 則可以在此處定義。

# 如果要控制 file-mcp 的 allow roots，也可以放這裡
FILE_MCP_ROOTS="YOUR_PROJECT_ROOT;Other allow roots..."

# Redmine MCP
REDMINE_URL="YOUR_REDMINE_URL"
REDMINE_API_KEY="YOUR_REDMINE_API_KEY"

# MsSQL (dev-doc-mcp)
# 建議使用唯讀帳號，只查 metadata，不查資料列
MSSQL_CONN="Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASS;Encrypt=true;TrustServerCertificate=true;"

# Git MCP
# 若未設定，會 fallback 到 FILE_MCP_ROOTS 或 process.cwd()
GIT_MCP_ROOTS="YOUR_PROJECT_ROOT;Other git roots..."

# DB Metadata MCP
# 建議使用唯讀帳號。支援多組 connection alias。
# DB_METADATA_CONNECTIONS 只放 placeholder，不可 commit 真實帳密。
DB_METADATA_DEFAULT_CONNECTION="dbexample-dev"
DB_METADATA_CONNECTIONS='{
  "dbexample-dev": {
    "type": "mssql",
    "displayName": "DB Example DEV",
    "description": "Development database for dbexample application metadata lookup.",
    "environment": "dev",
    "system": "dbexample",
    "database": "DBExample_DEV",
    "tags": ["dbexample", "dev", "development"],
    "connectionString": "Server=YOUR_DEV_SERVER;Database=DBExample_DEV;User Id=YOUR_READONLY_USER;Password=YOUR_PASSWORD;Encrypt=true;TrustServerCertificate=true;"
  },
  "dbexample-uat": {
    "type": "mssql",
    "displayName": "DB Example UAT",
    "description": "UAT database for dbexample application metadata lookup.",
    "environment": "uat",
    "system": "dbexample",
    "database": "DBExample_UAT",
    "tags": ["dbexample", "uat", "testing"],
    "connectionString": "Server=YOUR_UAT_SERVER;Database=DBExample_UAT;User Id=YOUR_READONLY_USER;Password=YOUR_PASSWORD;Encrypt=true;TrustServerCertificate=true;"
  }
}'

# Legacy single connection fallback for DB Metadata MCP.
# 若已設定 DB_METADATA_CONNECTIONS，通常不需要再設定此項。
DB_METADATA_MSSQL_CONN="Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_READONLY_USER;Password=YOUR_PASSWORD;Encrypt=true;TrustServerCertificate=true;"

# Test Runner MCP
# Commands 必須是 JSON object，value 必須是 string array，避免 shell injection。
TEST_RUNNER_ROOTS="YOUR_PROJECT_ROOT;Other test roots..."
TEST_RUNNER_COMMANDS='{"npm-test":["npm","test"],"dotnet-test":["dotnet","test"]}'

# Static Analysis MCP
STATIC_ANALYSIS_ROOTS="YOUR_PROJECT_ROOT;Other analysis roots..."
STATIC_ANALYSIS_COMMANDS='{"npm-lint":["npm","run","lint"],"npm-build":["npm","run","build"],"dotnet-build":["dotnet","build"]}'

# Secret Scan MCP
SECRET_SCAN_ROOTS="YOUR_PROJECT_ROOT;Other scan roots..."
