{
  "general": {
    "defaultApprovalMode": "default",
    "checkpointing": { "enabled": true }
  },
  "mcpServers": {
    "redmine": {
      "command": "node",
      "args": ["./packages/redmine-mcp/index.js"],
      "cwd": ".",
      "env": {
        "REDMINE_URL": "$REDMINE_URL",
        "REDMINE_API_KEY": "$REDMINE_API_KEY"
      },
      "trust": true
    },
    "localFiles": {
      "command": "node",
      "args": ["./packages/file-mcp/index.js"],
      "cwd": ".",
      "trust": false
    },
    "devDocs": {
      "command": "node",
      "args": ["./packages/dev-doc-mcp/index.js"],
      "cwd": ".",
      "env": {
        "MSSQL_CONN": "$MSSQL_CONN"
      },
      "trust": false
    },
    "flowchart": {
      "command": "node",
      "args": ["./packages/flowchart-mcp/index.js"],
      "cwd": ".",
      "trust": false
    },
    "git": {
      "command": "node",
      "args": ["./packages/git-mcp/index.js"],
      "cwd": ".",
      "env": {
        "GIT_MCP_ROOTS": "$GIT_MCP_ROOTS",
        "FILE_MCP_ROOTS": "$FILE_MCP_ROOTS"
      },
      "trust": false
    },
    "dbMetadata": {
      "command": "node",
      "args": ["./packages/db-metadata-mcp/index.js"],
      "cwd": ".",
      "env": {
        "DB_METADATA_MSSQL_CONN": "$DB_METADATA_MSSQL_CONN",
        "MSSQL_CONN": "$MSSQL_CONN"
      },
      "trust": false
    },
    "testRunner": {
      "command": "node",
      "args": ["./packages/test-runner-mcp/index.js"],
      "cwd": ".",
      "env": {
        "TEST_RUNNER_ROOTS": "$TEST_RUNNER_ROOTS",
        "TEST_RUNNER_COMMANDS": "$TEST_RUNNER_COMMANDS",
        "FILE_MCP_ROOTS": "$FILE_MCP_ROOTS"
      },
      "trust": false
    },
    "staticAnalysis": {
      "command": "node",
      "args": ["./packages/static-analysis-mcp/index.js"],
      "cwd": ".",
      "env": {
        "STATIC_ANALYSIS_ROOTS": "$STATIC_ANALYSIS_ROOTS",
        "STATIC_ANALYSIS_COMMANDS": "$STATIC_ANALYSIS_COMMANDS",
        "FILE_MCP_ROOTS": "$FILE_MCP_ROOTS"
      },
      "trust": false
    },
    "secretScan": {
      "command": "node",
      "args": ["./packages/secret-scan-mcp/index.js"],
      "cwd": ".",
      "env": {
        "SECRET_SCAN_ROOTS": "$SECRET_SCAN_ROOTS",
        "FILE_MCP_ROOTS": "$FILE_MCP_ROOTS"
      },
      "trust": false
    }
  },
  "security": {
    "enablePermanentToolApproval": false,
    "disableYoloMode": false
  }
}
